generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ARTISAN
  ADMIN
}

enum Plan {
  GRATUIT
  ESSENTIEL
  PRO
  PRO_PLUS
  // Nouveaux plans V2
  STARTER
  BUSINESS
}

enum PhotoType {
  SIMPLE
  AVANT
  APRES
}

enum BadgeType {
  SYSTEME
  CUSTOM
}

enum StatutDevis {
  NOUVEAU
  VU
  REPONDU
  ACCEPTE
  REFUSE
  ARCHIVE
}

enum ReplyType {
  MESSAGE
  QUOTE_UPLOAD
  QUOTE_INVOQUO
}

enum NotificationType {
  DEMANDE_DEVIS
  RDV_NOUVEAU
  RDV_CONFIRME
  RDV_ANNULE
  RELANCE
  AVIS
  CHANTIER_INVITE
}

model User {
  id               String   @id @default(cuid())
  email            String   @unique
  passwordHash     String   @map("password_hash")
  role             Role     @default(ARTISAN)
  emailVerified    Boolean  @default(false) @map("email_verified")
  magicLinkToken   String?  @map("magic_link_token")
  magicLinkExpiresAt DateTime? @map("magic_link_expires_at")
  magicTokenHash     String?   @unique @map("magic_token_hash")
  magicTokenExpires  DateTime? @map("magic_token_expires")
  magicRequestedAt   DateTime? @map("magic_requested_at")
  magicAttempts      Int       @default(0) @map("magic_attempts")
  refreshTokenHash String?  @map("refresh_token_hash")
  resetTokenHash     String?   @unique @map("reset_token_hash")
  resetTokenExpires  DateTime? @map("reset_token_expires")
  resetRequestedAt   DateTime? @map("reset_requested_at")
  resetAttempts      Int       @default(0) @map("reset_attempts")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  artisan          Artisan?

  @@map("users")
}

model Artisan {
  id              String   @id @default(cuid())
  userId          String   @unique @map("user_id")
  siret           String   @unique
  raisonSociale   String?  @map("raison_sociale")
  nomAffichage    String   @map("nom_affichage")
  prenom          String?
  nom             String?
  metierId        String?  @map("metier_id")
  description     String?  @db.Text
  telephone       String
  adresse         String?
  codePostal      String?  @map("code_postal")
  ville           String?
  latitude        Float?
  longitude       Float?
  codeInsee       String?  @map("code_insee")
  zoneRayonKm     Int      @default(15) @map("zone_rayon_km")
  experienceAnnees Int?    @map("experience_annees")
  noteMoyenne     Float    @default(0) @map("note_moyenne")
  nombreAvis      Int      @default(0) @map("nombre_avis")
  plan            Plan     @default(GRATUIT)
  stripeCustomerId     String?  @unique @map("stripe_customer_id")
  stripeSubscriptionId String?  @unique @map("stripe_subscription_id")
  stripePriceId        String?  @map("stripe_price_id")
  subscriptionStatus   String?  @map("subscription_status")
  invoiceCount         Int      @default(0) @map("invoice_count")
  leadsCompletsUtilises Int     @default(0) @map("leads_complets_utilises")
  invoiceCountResetAt  DateTime? @map("invoice_count_reset_at")
  profilCompletion Int     @default(0) @map("profil_completion")
  templateId      String   @default("classique") @map("template_id")
  colorPrimary    String   @default("#C4531A") @map("color_primary")
  colorAccent     String   @default("#E8A84C") @map("color_accent")
  photoLayout     String   @default("grid") @map("photo_layout")
  seoDescription  String?  @map("seo_description") @db.Text
  seoKeywords     String?  @map("seo_keywords") @db.Text
  vitrineConfig   Json?    @map("vitrine_config")
  seoGenerated    Json?    @map("seo_generated")
  seoGeneratedAt  DateTime? @map("seo_generated_at")
  googleBusinessUrl String? @map("google_business_url")
  facebookUrl     String?  @map("facebook_url")
  instagramUrl    String?  @map("instagram_url")
  siteWebUrl      String?  @map("site_web_url")
  actif           Boolean  @default(false)
  visible         Boolean  @default(true)
  slug            String   @unique
  logo            String?
  invoquoApiKey   String?  @map("invoquo_api_key")
  invoquoSiret    String?  @map("invoquo_siret")
  invoquoEnabled  Boolean  @default(false) @map("invoquo_enabled")
  deletedAt       DateTime? @map("deleted_at")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  user            User     @relation(fields: [userId], references: [id])
  metier          Metier?  @relation(fields: [metierId], references: [id])
  photos          Photo[]
  badges          Badge[]
  services        ServiceArtisan[]
  demandesDevis   DemandeDevis[]
  horaires        Horaire[]
  zones           ZoneIntervention[]
  notifications   Notification[]
  devisReplies    DevisReply[]
  tarification    Tarification?
  prestationTypes PrestationType[]
  devisList       Devis[]
  smsUsage        SmsUsage[]
  smsRecharges    SmsRecharge[]
  disponibilites  DisponibiliteHebdo[]
  joursFeries     JourFerie[]
  rdvList         RendezVousBativio[]
  chantiers       Chantier[]
  clients         Client[]
  artisanMetiers  ArtisanMetier[]
  demandesRecues  DemandeEnvoi[]
  tarifsMetiers   TarifHoraireMetier[]
  tarifsHoraire   Float?              @map("tarifs_horaire")
  tarifsMarges    Json?               @map("tarifs_marges")

  scoringData     Json?          @map("scoring_data")
  scoringScore    Float?         @map("scoring_score")
  scoringPercent  Int?           @map("scoring_percent")
  motifRefus      String?        @map("motif_refus") @db.Text
  scoringDate     DateTime?      @map("scoring_date")
  validationDate  DateTime?      @map("validation_date")
  validatedBy     String?        @map("validated_by")
  artisanStatus   String         @default("ONBOARDING") @map("artisan_status")

  // Plan override (admin)
  planOverride         String?   @map("plan_override")
  planOverrideRaison   String?   @map("plan_override_raison")
  planOverrideExpireAt DateTime? @map("plan_override_expire_at")

  // Vitrine SEO (Business only)
  villeSlug       String?  @map("ville_slug")
  metierSlugSeo   String?  @map("metier_slug_seo")
  seoTitle        String?  @map("seo_title")
  horairesTexte   String?  @map("horaires_texte") @db.Text
  zoneTexte       String?  @map("zone_texte") @db.Text

  @@index([ville, metierId])
  @@index([slug])
  @@index([plan])
  @@index([actif, visible])
  @@index([villeSlug, metierSlugSeo])
  @@map("artisans")
}

model Metier {
  id          String   @id @default(cuid())
  nom         String   @unique
  slug        String   @unique
  icone       String?
  label       String?  // "Plombier / Chauffagiste"
  categorie   String?  // "gros_oeuvre", "second_oeuvre", etc.
  arbreActif  Boolean  @default(false) @map("arbre_actif")
  ordre       Int      @default(0)
  createdAt   DateTime @default(now()) @map("created_at")

  artisans       Artisan[]
  artisanMetiers ArtisanMetier[]

  @@map("metiers")
}

model ArtisanMetier {
  id        String  @id @default(cuid())
  artisanId String  @map("artisan_id")
  metierId  String  @map("metier_id")
  principal Boolean @default(false)

  artisan   Artisan @relation(fields: [artisanId], references: [id], onDelete: Cascade)
  metier    Metier  @relation(fields: [metierId], references: [id], onDelete: Cascade)

  @@unique([artisanId, metierId])
  @@index([metierId])
  @@map("artisan_metiers")
}

model ArbreQuestions {
  id         String   @id @default(cuid())
  metierSlug String   @unique @map("metier_slug")
  questions  Json
  version    Int      @default(1)
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@map("arbres_questions")
}

model MessageDevis {
  id        String   @id @default(cuid())
  demandeId String   @map("demande_id")
  auteur    String   // "client" ou "artisan"
  contenu   String   @db.Text
  lu        Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  demande   DemandeDevis @relation(fields: [demandeId], references: [id], onDelete: Cascade)

  @@index([demandeId, createdAt])
  @@map("messages_devis")
}

model DevisPhoto {
  id        String   @id @default(cuid())
  demandeId String   @map("demande_id")
  url       String
  auteur    String   // "client" ou "artisan"
  createdAt DateTime @default(now()) @map("created_at")

  demande   DemandeDevis @relation(fields: [demandeId], references: [id], onDelete: Cascade)

  @@index([demandeId])
  @@map("devis_photos")
}

model Ville {
  id          String   @id @default(cuid())
  nom         String   @unique
  slug        String   @unique
  codePostal  String?  @map("code_postal")
  departement String?
  latitude    Float?
  longitude   Float?
  seoTitle       String?  @map("seo_title")
  seoDescription String?  @map("seo_description") @db.Text
  contenuSeo     String?  @map("contenu_seo") @db.Text
  actif          Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("villes")
}

model Photo {
  id                 String    @id @default(cuid())
  artisanId          String    @map("artisan_id")
  cloudinaryPublicId String?   @map("cloudinary_public_id")
  url                String
  titre              String?
  type               PhotoType @default(SIMPLE)
  paireId            String?   @map("paire_id")
  ordre              Int       @default(0)
  createdAt          DateTime  @default(now()) @map("created_at")

  artisan            Artisan   @relation(fields: [artisanId], references: [id], onDelete: Cascade)

  @@index([artisanId, ordre])
  @@map("photos")
}

model Badge {
  id        String    @id @default(cuid())
  artisanId String    @map("artisan_id")
  type      BadgeType @default(SYSTEME)
  nom       String
  icone     String?
  couleur   String?
  createdAt DateTime  @default(now()) @map("created_at")

  artisan   Artisan   @relation(fields: [artisanId], references: [id], onDelete: Cascade)

  @@index([artisanId])
  @@map("badges")
}

model BadgeSysteme {
  id          String   @id @default(cuid())
  nom         String   @unique
  description String?
  icone       String?
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("badges_systeme")
}

model ServiceArtisan {
  id            String   @id @default(cuid())
  artisanId     String   @map("artisan_id")
  titre         String
  description   String?  @db.Text
  prixIndicatif String?  @map("prix_indicatif")
  ordre         Int      @default(0)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  artisan       Artisan  @relation(fields: [artisanId], references: [id], onDelete: Cascade)

  @@index([artisanId])
  @@map("services_artisan")
}

model DemandeDevis {
  id               String      @id @default(cuid())
  artisanId        String      @map("artisan_id")
  nomClient        String      @map("nom_client")
  telephoneClient  String      @map("telephone_client")
  emailClient      String?     @map("email_client")
  descriptionBesoin String     @map("description_besoin") @db.Text
  statut           StatutDevis @default(NOUVEAU)
  reponduAt        DateTime?   @map("repondu_at")
  relanceEnvoyee   Boolean     @default(false) @map("relance_envoyee")
  relanceCount     Int         @default(0) @map("relance_count")
  urgence          String      @default("normal") // "normal" | "urgent"
  responseToken    String?     @map("response_token")
  // Chat devis — champs étendus
  clientVille      String?     @map("client_ville")
  metierId         String?     @map("metier_devis_id")
  reponses         Json?       // réponses structurées du chat devis
  resumeTexte      String?     @map("resume_texte") @db.Text
  devisIA          Json?       @map("devis_ia")
  devisIAGenere    Boolean     @default(false) @map("devis_ia_genere")
  devisFinalUrl    String?     @map("devis_final_url")
  devisMontantHT   Float?      @map("devis_montant_ht")
  clientId         String?     @map("client_id")
  expiresAt        DateTime?   @map("expires_at")
  createdAt        DateTime    @default(now()) @map("created_at")
  updatedAt        DateTime    @updatedAt @map("updated_at")

  artisan          Artisan     @relation(fields: [artisanId], references: [id], onDelete: Cascade)
  client           Client?     @relation(fields: [clientId], references: [id])
  replies          DevisReply[]
  messages         MessageDevis[]
  photosDevis      DevisPhoto[]

  @@index([artisanId, statut])
  @@index([artisanId, createdAt])
  @@index([responseToken])
  @@index([emailClient])
  @@map("demandes_devis")
}

model DevisReply {
  id                 String    @id @default(cuid())
  demandeDevisId     String    @map("demande_devis_id")
  artisanId          String    @map("artisan_id")
  message            String?   @db.Text
  attachmentUrl      String?   @map("attachment_url")
  attachmentFilename String?   @map("attachment_filename")
  type               ReplyType @default(MESSAGE)
  createdAt          DateTime  @default(now()) @map("created_at")

  demandeDevis       DemandeDevis @relation(fields: [demandeDevisId], references: [id], onDelete: Cascade)
  artisan            Artisan      @relation(fields: [artisanId], references: [id], onDelete: Cascade)

  @@index([demandeDevisId, createdAt])
  @@map("devis_replies")
}

model Horaire {
  id             String    @id @default(cuid())
  artisanId      String    @map("artisan_id")
  jourSemaine    Int       @map("jour_semaine")
  ouvert         Boolean   @default(true)
  heureOuverture String?   @map("heure_ouverture")
  heureFermeture String?   @map("heure_fermeture")

  artisan        Artisan   @relation(fields: [artisanId], references: [id], onDelete: Cascade)

  @@index([artisanId])
  @@map("horaires")
}

model ZoneIntervention {
  id        String  @id @default(cuid())
  artisanId String  @map("artisan_id")
  ville     String

  artisan   Artisan @relation(fields: [artisanId], references: [id], onDelete: Cascade)

  @@index([artisanId])
  @@map("zones_intervention")
}

model Notification {
  id        String           @id @default(cuid())
  artisanId String           @map("artisan_id")
  type      NotificationType
  titre     String
  message   String?          @db.Text
  lu        Boolean          @default(false)
  createdAt DateTime         @default(now()) @map("created_at")

  artisan   Artisan          @relation(fields: [artisanId], references: [id], onDelete: Cascade)

  @@index([artisanId, createdAt])
  @@map("notifications")
}

model Tarification {
  id                      String   @id @default(cuid())
  artisanId               String   @unique @map("artisan_id")
  tarifHoraire            Float    @map("tarif_horaire")
  tarifUrgence            Float?   @map("tarif_urgence")
  minimumFacture          Float?   @map("minimum_facture")
  minimumHeures           Float?   @map("minimum_heures")
  fraisDeplacementType    String   @default("forfait") @map("frais_deplacement_type")
  fraisDeplacementMontant Float    @default(30) @map("frais_deplacement_montant")
  prixKm                  Float?   @map("prix_km")
  margeFournitures        Float    @default(25) @map("marge_fournitures")
  tvaDefault              Float    @default(10) @map("tva_default")
  assuranceNumero         String?  @map("assurance_numero")
  assuranceNom            String?  @map("assurance_nom")
  fourniturePolicy        String   @default("artisan_fournit") @map("fourniture_policy")
  indiceBtRef             String?  @map("indice_bt_ref")
  zonesIntervention       Json?    @map("zones_intervention")
  notesTarif              String?  @map("notes_tarif") @db.Text
  createdAt               DateTime @default(now()) @map("created_at")
  updatedAt               DateTime @updatedAt @map("updated_at")

  artisan                 Artisan  @relation(fields: [artisanId], references: [id], onDelete: Cascade)

  @@map("tarifications")
}

model PrestationType {
  id               String   @id @default(cuid())
  artisanId        String   @map("artisan_id")
  designation      String
  description      String?  @db.Text
  unite            String
  prixUnitaire     Float    @map("prix_unitaire")
  categorie        String?
  metierSlug       String?  @map("metier_slug")
  tvaApplicable    Float?   @map("tva_applicable")
  inclutFourniture Boolean  @default(true) @map("inclut_fourniture")
  isCustom         Boolean  @default(false) @map("is_custom")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @default(now()) @updatedAt @map("updated_at")

  artisan          Artisan  @relation(fields: [artisanId], references: [id], onDelete: Cascade)

  @@index([artisanId])
  @@index([metierSlug])
  @@map("prestation_types")
}

enum DevisStatut {
  BROUILLON
  ENVOYE
  VU
  ACCEPTE
  REFUSE
  EXPIRE
}

model Devis {
  id                  String      @id @default(cuid())
  artisanId           String      @map("artisan_id")
  numero              String      @unique
  clientNom           String      @map("client_nom")
  clientEmail         String?     @map("client_email")
  clientTelephone     String?     @map("client_telephone")
  clientAdresse       String?     @map("client_adresse")
  objet               String
  niveauGamme         String      @default("standard") @map("niveau_gamme")
  fournitureOption    String      @default("artisan_fournit") @map("fourniture_option")
  postes              Json
  totalHT             Float       @map("total_ht")
  tauxTVA             Float       @map("taux_tva")
  montantTVA          Float       @map("montant_tva")
  totalTTC            Float       @map("total_ttc")
  dureeEstimee        String?     @map("duree_estimee")
  conditionsPaiement  String?     @map("conditions_paiement")
  notes               String?     @db.Text
  mentionSousReserve  Boolean     @default(true) @map("mention_sous_reserve")
  validiteJours       Int         @default(30) @map("validite_jours")
  statut              DevisStatut @default(BROUILLON)
  envoyeAt            DateTime?   @map("envoye_at")
  vuAt                DateTime?   @map("vu_at")
  accepteAt           DateTime?   @map("accepte_at")
  refuseAt            DateTime?   @map("refuse_at")
  pdfUrl              String?     @map("pdf_url")
  viewToken           String?     @unique @map("view_token")
  devisRequestId      String?     @map("devis_request_id")

  // Devis IA (V1 Bativio)
  source              String      @default("MANUEL")
  demandeProjetId     String?     @map("demande_projet_id")
  demandeProjet       DemandeProjet? @relation(fields: [demandeProjetId], references: [id])
  promptVersion       String?     @map("prompt_version")
  modelUsed           String?     @map("model_used")
  tokensIn            Int?        @map("tokens_in")
  tokensOut           Int?        @map("tokens_out")
  costEur             Decimal?    @db.Decimal(10, 4) @map("cost_eur")
  mentionsJson        Json?       @map("mentions_json")

  // Lien CRM + chantier (audit P0)
  clientId            String?     @map("client_id")
  client              Client?     @relation(fields: [clientId], references: [id])
  chantiers           Chantier[]

  createdAt           DateTime    @default(now()) @map("created_at")
  updatedAt           DateTime    @updatedAt @map("updated_at")

  artisan             Artisan     @relation(fields: [artisanId], references: [id], onDelete: Cascade)

  @@index([artisanId, statut])
  @@index([artisanId, createdAt])
  @@index([demandeProjetId])
  @@index([clientId])
  @@map("devis")
}

model SiteConfig {
  id          String   @id @default(cuid())
  cle         String   @unique
  valeur      String
  type        String   @default("string")
  categorie   String
  label       String
  description String?
  updatedAt   DateTime @updatedAt @map("updated_at")
  updatedBy   String?  @map("updated_by")

  @@index([categorie])
  @@map("site_config")
}

model SmsUsage {
  id        String  @id @default(cuid())
  artisanId String  @map("artisan_id")
  mois      String
  count     Int     @default(0)
  quota     Int     @default(30)

  artisan   Artisan @relation(fields: [artisanId], references: [id], onDelete: Cascade)

  @@unique([artisanId, mois])
  @@map("sms_usage")
}

model SmsRecharge {
  id              String   @id @default(cuid())
  artisanId       String   @map("artisan_id")
  quantite        Int
  prix            Float
  stripePaymentId String?  @map("stripe_payment_id")
  createdAt       DateTime @default(now()) @map("created_at")

  artisan         Artisan  @relation(fields: [artisanId], references: [id], onDelete: Cascade)

  @@map("sms_recharges")
}

enum JourSemaine {
  LUNDI
  MARDI
  MERCREDI
  JEUDI
  VENDREDI
  SAMEDI
  DIMANCHE
}

enum RdvStatut {
  CONFIRME
  EN_ATTENTE
  ANNULE
  TERMINE
  NO_SHOW
}

model DisponibiliteHebdo {
  id         String       @id @default(cuid())
  artisanId  String       @map("artisan_id")
  jour       JourSemaine
  heureDebut String       @map("heure_debut")
  heureFin   String       @map("heure_fin")
  pauseDebut String?      @map("pause_debut")
  pauseFin   String?      @map("pause_fin")
  isActive   Boolean      @default(true) @map("is_active")
  dureeSlot  Int          @default(60) @map("duree_slot")

  artisan    Artisan      @relation(fields: [artisanId], references: [id], onDelete: Cascade)

  @@unique([artisanId, jour])
  @@map("disponibilites_hebdo")
}

model JourFerie {
  id        String   @id @default(cuid())
  artisanId String   @map("artisan_id")
  date      DateTime
  motif     String?

  artisan   Artisan  @relation(fields: [artisanId], references: [id], onDelete: Cascade)

  @@index([artisanId, date])
  @@map("jours_feries")
}

model RendezVousBativio {
  id              String    @id @default(cuid())
  artisanId       String    @map("artisan_id")
  clientNom       String    @map("client_nom")
  clientEmail     String?   @map("client_email")
  clientTelephone String    @map("client_telephone")
  dateDebut       DateTime  @map("date_debut")
  dateFin         DateTime  @map("date_fin")
  dureeMinutes    Int       @default(60) @map("duree_minutes")
  objet           String?
  adresse         String?
  notes           String?   @db.Text
  statut          RdvStatut @default(EN_ATTENTE)
  devisId         String?   @map("devis_id")
  rappelSmsEnvoye Boolean   @default(false) @map("rappel_sms_envoye")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  artisan         Artisan   @relation(fields: [artisanId], references: [id], onDelete: Cascade)

  @@index([artisanId, dateDebut])
  @@index([artisanId, statut])
  @@map("rendez_vous_bativio")
}

model Settings {
  id         String   @id @default("singleton")
  adminEmail String   @default("contact@bativio.com") @map("admin_email")
  updatedAt  DateTime @updatedAt @map("updated_at")
  @@map("settings")
}

// ── Planning chantier ──

enum ChantierStatut {
  PLANIFIE
  EN_COURS
  TERMINE
  ANNULE
  REPORTE
}

enum CollaborateurSource {
  MANUEL
  BATIVIO
  GMAIL
}

model Chantier {
  id              String          @id @default(cuid())
  artisanId       String          @map("artisan_id")
  nom             String
  adresse         String?
  ville           String?
  clientNom       String?         @map("client_nom")
  clientTelephone String?         @map("client_telephone")
  clientId        String?         @map("client_id")
  couleur         String          @default("#C4531A")
  dateDebut       DateTime        @map("date_debut")
  dateFin         DateTime        @map("date_fin")
  heureDebut      String?         @map("heure_debut")
  heureFin        String?         @map("heure_fin")
  notes           String?         @db.Text
  statut          ChantierStatut  @default(PLANIFIE)
  devisId         String?         @map("devis_id")
  montantDevis    Float?          @map("montant_devis")
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")

  artisan         Artisan         @relation(fields: [artisanId], references: [id], onDelete: Cascade)
  client          Client?         @relation(fields: [clientId], references: [id])
  devis           Devis?          @relation(fields: [devisId], references: [id])
  collaborateurs  ChantierCollaborateur[]

  @@index([artisanId, dateDebut])
  @@index([artisanId, statut])
  @@index([clientId])
  @@index([devisId])
  @@map("chantiers")
}

model ChantierCollaborateur {
  id               String              @id @default(cuid())
  chantierId       String              @map("chantier_id")
  nom              String
  email            String?
  telephone        String?
  role             String?             @default("collaborateur")
  source           CollaborateurSource @default(MANUEL)
  artisanBativioId String?             @map("artisan_bativio_id")

  chantier         Chantier            @relation(fields: [chantierId], references: [id], onDelete: Cascade)

  @@index([chantierId])
  @@index([artisanBativioId])
  @@map("chantier_collaborateurs")
}

// ── CRM Client ──

model Client {
  id              String   @id @default(cuid())
  artisanId       String   @map("artisan_id")
  nom             String
  prenom          String?
  email           String?
  telephone       String?
  adresse         String?
  codePostal      String?  @map("code_postal")
  ville           String?
  siret           String?
  notes           String?  @db.Text
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  artisan         Artisan  @relation(fields: [artisanId], references: [id], onDelete: Cascade)
  demandes        DemandeDevis[]
  devis           Devis[]
  chantiers       Chantier[]

  @@unique([artisanId, email])
  @@index([artisanId])
  @@index([artisanId, nom])
  @@map("clients")
}

// ═══════════════════════════════════════════════════════════
// DEVIS IA — V1 Bativio
// ═══════════════════════════════════════════════════════════

enum DemandeProjetStatut {
  NOUVELLE
  EN_ATTENTE
  ROUTEE
  DEVIS_ENVOYE
  CLOTUREE
}

enum ModeRoutage {
  MANUEL
  AUTO_TOUS
  AUTO_CONCERNES
  AUTO_PRO
  AUTO_BUSINESS
}

enum KbDocType {
  INDICE_BT
  TARIF_MARCHE
  MENTION_LEGALE
  TVA_TAUX
  DTU_NORME
  EXEMPLE_DEVIS
  PRIX_MATERIAU
  GUIDE_QUANTITE
  GUIDE_QUALIF
}

model DemandeProjet {
  id              String   @id @default(cuid())

  description     String   @db.Text
  villeLabel      String?  @map("ville_label")
  villeSlug       String?  @map("ville_slug")
  lat             Float?
  lon             Float?

  metierDetecte   String?  @map("metier_detecte")
  qualifJson      Json?    @map("qualif_json")
  qualifScore     Int?     @map("qualif_score")
  preDevisJson    Json?    @map("pre_devis_json")

  contactNom      String?  @map("contact_nom")
  contactEmail    String?  @map("contact_email")
  contactTel      String?  @map("contact_tel")

  photos          Json?

  statut          DemandeProjetStatut @default(NOUVELLE)
  source          String?

  modeRoutage     ModeRoutage @default(MANUEL) @map("mode_routage")
  routageBy       String?     @map("routage_by")
  routageAt       DateTime?   @map("routage_at")

  // Tracking contact client par webmaster
  webmasterNotes        String?   @db.Text @map("webmaster_notes")
  webmasterJoignableA   DateTime? @map("webmaster_joignable_a")
  webmasterContactType  String?   @map("webmaster_contact_type")
  webmasterContactResult String?  @map("webmaster_contact_result")

  envois          DemandeEnvoi[]
  devis           Devis[]
  contacts        DemandeContact[]

  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("demande_projet")
  @@index([statut])
  @@index([metierDetecte])
  @@index([createdAt])
}

model DemandeContact {
  id          String   @id @default(cuid())
  demandeId   String   @map("demande_id")
  demande     DemandeProjet @relation(fields: [demandeId], references: [id], onDelete: Cascade)
  userId      String   @map("user_id")
  type        String
  canal       String
  note        String?  @db.Text
  result      String?
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("demande_contact")
  @@index([demandeId])
  @@index([userId])
}

model OtpVerification {
  id          String   @id @default(cuid())
  telephone   String
  codeHash    String   @map("code_hash")
  ip          String?
  verifiedAt  DateTime? @map("verified_at")
  expiresAt   DateTime @map("expires_at")
  attempts    Int      @default(0)

  createdAt   DateTime @default(now()) @map("created_at")

  @@map("otp_verification")
  @@index([telephone])
  @@index([expiresAt])
}

model DemandeEnvoi {
  id          String   @id @default(cuid())
  demandeId   String   @map("demande_id")
  demande     DemandeProjet @relation(fields: [demandeId], references: [id], onDelete: Cascade)
  artisanId   String   @map("artisan_id")
  artisan     Artisan  @relation(fields: [artisanId], references: [id], onDelete: Cascade)

  sentAt      DateTime @default(now()) @map("sent_at")
  seenAt      DateTime? @map("seen_at")
  respondedAt DateTime? @map("responded_at")
  rejectedAt  DateTime? @map("rejected_at")

  emailId     String?  @map("email_id")

  @@map("demande_envoi")
  @@unique([demandeId, artisanId])
  @@index([artisanId])
}

model KbDocument {
  id          String   @id @default(cuid())
  slug        String   @unique
  type        KbDocType
  title       String
  content     String   @db.Text
  metadata    Json?
  source      String?
  periodeRef  String?  @map("periode_ref")
  validFrom   DateTime @default(now()) @map("valid_from")
  validTo     DateTime? @map("valid_to")

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("kb_document")
  @@index([type])
  @@index([validFrom])
}

model RoutageSettings {
  id                String   @id @default(cuid())
  scope             String   @unique
  modeDefault       ModeRoutage @default(MANUEL) @map("mode_default")
  delaiManuelMin    Int?     @map("delai_manuel_min")
  emailTemplate     String?  @db.Text @map("email_template")

  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@map("routage_settings")
}

// Catalogue standardisé des prestations BTP (Rhône-Alpes 2026)
// Utilisé pour matching IA + auto-complétion côté artisan
model CataloguePrestation {
  id              String   @id @default(cuid())
  code            String   @unique
  metierSlug      String   @map("metier_slug")
  categorie       String?
  designation     String
  description     String?  @db.Text
  unite           String
  prixHtBas       Float    @map("prix_ht_bas")
  prixHtMoyen     Float    @map("prix_ht_moyen")
  prixHtHaut      Float    @map("prix_ht_haut")
  motsCles        Json     @map("mots_cles")
  dureeMoyenneH   Float?   @map("duree_moyenne_h")
  tvaDefault      Float?   @map("tva_default")
  region          String   @default("rhone-alpes")
  annee           Int      @default(2026)

  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("catalogue_prestation")
  @@index([metierSlug])
  @@index([code])
}

// Tarifs horaires multi-métiers par artisan (un artisan peut être plombier + électricien avec des tarifs différents)
model TarifHoraireMetier {
  id              String   @id @default(cuid())
  artisanId       String   @map("artisan_id")
  artisan         Artisan  @relation(fields: [artisanId], references: [id], onDelete: Cascade)
  metierSlug      String   @map("metier_slug")
  metierNom       String   @map("metier_nom")
  tarifHoraire    Float    @map("tarif_horaire")
  tarifUrgence    Float?   @map("tarif_urgence")
  tarifWeekend    Float?   @map("tarif_weekend")
  minimumFacture  Float?   @map("minimum_facture")
  minimumHeures   Float?   @map("minimum_heures")
  notes           String?  @db.Text

  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("tarif_horaire_metier")
  @@unique([artisanId, metierSlug])
  @@index([artisanId])
}
